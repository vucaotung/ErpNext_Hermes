ERPNEXT_BASE_URL={{ bridge_erpnext_base_url }}
BRIDGE_RATE_LIMIT_PER_MINUTE={{ bridge_rate_limit_per_minute }}
BRIDGE_IDEMPOTENCY_DB=/data/idempotency.sqlite3
BRIDGE_AUDIT_LOG=/data/audit.log
BRIDGE_PROFILE_NAMES={{ hermes_profiles | selectattr('enabled', 'defined') | selectattr('enabled') | map(attribute='name') | list | union(hermes_profiles | rejectattr('enabled', 'defined') | map(attribute='name') | list) | join(',') }}
{% for profile in hermes_profiles %}
{% if profile.enabled | default(true) and profile.erpnext_api_user %}
PROFILE_{{ profile.name | upper | replace('-', '_') }}_SHARED_SECRET={{ lookup('vars', 'vault_bridge_shared_secret_' + (profile.name | replace('-', '_'))) }}
PROFILE_{{ profile.name | upper | replace('-', '_') }}_API_KEY={{ lookup('vars', profile.erpnext_api_key_var) }}
PROFILE_{{ profile.name | upper | replace('-', '_') }}_API_SECRET={{ lookup('vars', profile.erpnext_api_secret_var) }}
PROFILE_{{ profile.name | upper | replace('-', '_') }}_ROLE={{ profile.name }}
PROFILE_{{ profile.name | upper | replace('-', '_') }}_EMAIL={{ profile.erpnext_api_user }}
{% endif %}
{% endfor %}
