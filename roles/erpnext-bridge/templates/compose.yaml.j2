services:
  erpnext-bridge:
    build:
      context: ./src
    image: "{{ bridge_image }}"
    container_name: erpnext-bridge
    restart: unless-stopped
    env_file:
      - ./.env
    volumes:
      - ./data:/data
    networks:
      - platform-internal
      # ERPNext's frontend container (the only container the bridge is
      # actually allowed to call — mục 2.3) lives on the frappe_docker
      # stack's own "proxy-net" network under the alias "erpnext-frontend",
      # not on platform-internal. Without also joining proxy-net, the
      # bridge can't resolve that hostname at all (confirmed: "Temporary
      # failure in name resolution").
      - proxy-net
    # Internal only — Caddy/Telegram never reach this directly, only Hermes
    # containers on the platform-internal network do (mục 9 architecture).
    # Also published to 127.0.0.1 only (not 0.0.0.0) so a native, non-Dockerized
    # Hermes process on the same host (e.g. the native Hermes Agent CLI) can
    # reach it via lo