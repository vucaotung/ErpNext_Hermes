OPENROUTER_API_KEY={{ vault_openrouter_api_key }}
TOKENHUB_API_KEY={{ vault_tokenhub_api_key }}
TELEGRAM_BOT_TOKEN={{ lookup('vars', item.telegram_bot_token_var) if item.telegram_bot_token_var else '' }}
TELEGRAM_ALLOWED_USERS={{ item.allowed_users | join(',') }}
TELEGRAM_GROUP_ALLOWED_CHATS={{ item.group_allowed_chats | join(',') }}
{% if item.erpnext_api_user %}
# Only used by this profile's skills when calling the ERPNext API Bridge.
# The bridge itself resolves the *real* ERPNext identity from this shared
# secret server-side — Hermes never sees/handles the ERPNext API key.
BRIDGE_BASE_URL=http://erpnext-bridge:{{ bridge_internal_port }}
BRIDGE_SHARED_SECRET={{ lookup('vars', 'vault_bridge_shared_secret_' + (item.name | replace('-', '_'))) }}
{% endif %}
