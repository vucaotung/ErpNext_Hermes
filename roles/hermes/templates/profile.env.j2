# Second Brain vault for the built-in Obsidian skill - see
# docs/wiki/00_home.md for what this is and the 5 organizing principles.
# Shared across profiles (same vault, not per-profile) so any profile's
# chat can read/append the same accumulated project knowledge.
OBSIDIAN_VAULT_PATH={{ hermes_wiki_path }}
OPENROUTER_API_KEY={{ vault_openrouter_api_key }}
TOKENHUB_API_KEY={{ vault_tokenhub_api_key }}
TELEGRAM_BOT_TOKEN={{ lookup('vars', item.telegram_bot_token_var) if item.telegram_bot_token_var else '' }}
TELEGRAM_ALLOWED_USERS={{ item.allowed_users | join(',') }}
TELEGRAM_GROUP_ALLOWED_CHATS={{ item.group_allowed_chats | join(',') }}
{% if item.erpnext_api_user %}
# Only used by this profile's skills when calling the ERPNext API Bridge.
# The bridge itself resolves the *real* ERPNext identity from this shared
# secret server-side - Hermes never sees/handles the ERPNext API key.
#
# Hermes runs bare-metal on the host (not in the erpnext-bridge container's
# Docker network - confirmed against the live VPS: the hostname
# "erpnext-bridge" does not resolve from the host and a profile .env that
# still had it caused every /link, /mytasks, /assign hook call to fail with
# a DNS error). The bridge container publishes its port to loopback only
# (roles/erpnext-bridge/templates/compose.yaml.j2 -> "127.0.0.1:{{ bridge_internal_port }}:{{ bridge_internal_port }}"),
# so bare-metal Hermes must reach it there.
BRIDGE_BASE_URL=http://127.0.0.1:{{ bridge_internal_port }}
BRIDGE_SHARED_SECRET={{ lookup('vars', 'vault_bridge_shared_secret_' + (item.name | replace('-', '_'))) }}
{% endif %}
