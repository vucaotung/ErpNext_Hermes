---
# Encrypt the real file with:
# ansible-vault encrypt inventories/production/group_vars/vault.yml

vault_erpnext_db_password: CHANGE_ME
vault_erpnext_admin_password: CHANGE_ME
vault_openrouter_api_key: CHANGE_ME
vault_tokenhub_api_key: CHANGE_ME

vault_telegram_ops_bot_token: CHANGE_ME
vault_telegram_staff_bot_token: CHANGE_ME
vault_telegram_sales_bot_token: CHANGE_ME

# Create dedicated, scope-limited ERPNext API users after ERPNext is
# initialized (see apps/hermes_ops/README.md and playbooks/provision_erpnext.yml).
# Never issue the Administrator API key to Hermes.
vault_erpnext_ops_api_key: CHANGE_ME_LATER
vault_erpnext_ops_api_secret: CHANGE_ME_LATER
vault_erpnext_staff_api_key: CHANGE_ME_LATER
vault_erpnext_staff_api_secret: CHANGE_ME_LATER
vault_erpnext_sales_api_key: CHANGE_ME_LATER
vault_erpnext_sales_api_secret: CHANGE_ME_LATER

# Shared secret between Hermes profiles and the ERPNext API Bridge
# (bridge validates this per-profile before accepting any tool call).
# Variable name must be vault_bridge_shared_secret_<profile name with "-" -> "_">.
vault_bridge_shared_secret_ops_admin: CHANGE_ME
vault_bridge_shared_secret_staff_work: CHANGE_ME
vault_bridge_shared_secret_sales_crm: CHANGE_ME

# Off-site backup (rclone remote, e.g. S3-compatible / Backblaze B2 / R2).
vault_offsite_access_key_id: CHANGE_ME
vault_offsite_secret_access_key: CHANGE_ME
vault_offsite_endpoint: CHANGE_ME
