   "options": "DM\nGroup\nTopic\nERPNext"
  },
  {
   "fieldname": "source_chat_id",
   "label": "Source Chat ID",
   "fieldtype": "Data"
  },
  {
   "fieldname": "source_topic_id",
   "label": "Source Topic ID",
   "fieldtype": "Data"
  },
  {
   "fieldname": "column_break_1",
   "fieldtype": "Column Break"
  },
  {
   "fieldname": "section_break_target",
   "fieldtype": "Section Break",
   "label": "Target"
  },
  {
   "fieldname": "target_type",
   "label": "Target Type",
   "fieldtype": "Select",
   "options": "DM\nGroup\nTopic"
  },
  {
   "fieldname": "target_chat_id",
   "label": "Target Chat ID",
   "fieldtype": "Data"
  },
  {
   "fieldname": "target_topic_id",
   "label": "Target Topic ID",
   "fieldtype": "Data"
  },
  {
   "fieldname": "section_break_policy",
   "fieldtype": "Section Break",
   "label": "Policy"
  },
  {
   "fieldname": "delivery_mode",
   "label": "Delivery Mode",
   "fieldtype": "Select",
   "options": "Notify\nSummarize\nEscalate\nApproval\nDirect Message\nTopic Message"
  },
  {
   "fieldname": "data_classification",
   "label": "Data Classification",
   "fieldtype": "Select",
   "options": "Public\nInternal\nSensitive",
