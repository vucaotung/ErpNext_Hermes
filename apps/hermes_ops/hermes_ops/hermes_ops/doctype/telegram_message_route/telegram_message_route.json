   "unique": 1
  },
  {
   "fieldname": "event_type",
   "label": "Event Type",
   "fieldtype": "Data",
   "reqd": 1,
   "description": "e.g. task_progress_update, opportunity_won, task_blocked_escalation"
  },
  {
   "fieldname": "enabled",
   "label": "Enabled",
   "fieldtype": "Check",
   "default": "1"
  },
  {
