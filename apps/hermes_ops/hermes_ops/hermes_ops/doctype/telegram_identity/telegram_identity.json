{
 "doctype": "DocType",
 "name": "Telegram Identity",
 "module": "Hermes Ops",
 "custom": 0,
 "istable": 0,
 "editable_grid": 1,
 "track_changes": 1,
 "naming_rule": "By fieldname",
 "autoname": "field:telegram_user_id",
 "sort_field": "modified",
 "sort_order": "DESC",
 "fields": [
  {
   "fieldname": "telegram_user_id",
   "label": "Telegram User ID",
   "fieldtype": "Data",
   "reqd": 1,
   "unique": 1,
   "description": "Numeric Telegram user ID. Never store @username here — usernames are not permission keys (mục 5.4)."
  },
  {
   "fieldname": "telegram_username",
   "label": "Telegram Username",
   "fieldtype": "Data"
  },
  {
   "fieldname": "column_break_1",
   "fieldtype": "Column Break"
  },
  {
   "fieldname": "erpnext_user",
   "label": "ERPNext User",
   "fieldtype": "Link",
   "options": "User",
   "reqd": 1
  },
  {
   "fieldname": "employee",
   "label": "Employee",
   "fieldtype": "Link",
   "options": "Employee"
  },
  {
   "fieldname": "department",
   "label": "Department",
   "fieldtype": "Link",
   "options": "Department",
   "fetch_from": "employee.department",
   "read_only": 1
  },
  {
   "fieldname": "manager",
   "label": "Manager (User)",
   "fieldtype": "Link",
   "options": "User"
  },
  {
   "fieldname": "section_break_1",
   "fieldtype": "Section Break"
  },
  {
   "fieldname": "allowed_profile",
   "label": "Allowed Hermes Profile",
   "fieldtype": "Select",
   "options": "ops-admin\nstaff-work\nsales-crm",
   "reqd": 1,
   "description": "Which Hermes profile/bot this identity is allowed to use. Enforced by the API Bridge on every tool call, not just by Telegram allowlist."
  },
  {
   "fieldname": "active",
   "label": "Active",
   "fieldtype": "Check",
   "default": "1"
  },
  {
   "fieldname": "column_break_2",
   "fieldtype": "Column Break"
  },
  {
   "fieldname": "linked_at",
   "label": "Linked At",
   "fieldtype": "Datetime",
   "read_only": 1
  },
  {
   "fieldname": "revoked_at",
   "label": "Revoked At",
   "fieldtype": "Datetime",
   "read_only": 1
  },
  {
   "fieldname": "link_code_hash",
   "label": "Link Code Hash",
   "fieldtype": "Data",
   "hidden": 1,
   "description": "SHA-256 of the one-time onboarding code, cleared after successful /link. Never store the plaintext code."
  }
 ],
